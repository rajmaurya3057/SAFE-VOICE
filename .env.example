# Google / Gemini API Key
# Used for Gemini AI tactical advice and as a fallback for Google Maps
API_KEY=

# Dedicated Google Maps API Key (Optional, will fallback to API_KEY if not set)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Twilio Credentials for SMS Alerts
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=

# Application URL (Used for generating tracking links in SMS)
# Example: https://your-app-id.run.app
APP_URL=
